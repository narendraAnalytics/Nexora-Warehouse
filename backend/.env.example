# ─── LLM ───────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL_PRO=llama-3.3-70b-versatile
GROQ_MODEL_FLASH=llama-3.1-8b-instant

# ─── Database (Neon PostgreSQL) ─────────────────────────
NEON_DB_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# ─── Redis ──────────────────────────────────────────────
REDIS_HOST=your-redis-host.db.redis.io
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=your-redis-password

# ─── Vector DB (ChromaDB) ───────────────────────────────
CHROMA_MODE=local
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ─── Email (Resend) ─────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=admin@yourdomain.com
RESEND_FROM_NAME=NexoraWarehouse

# ─── Events (Inngest) — Phase 8+ ────────────────────────
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# ─── Auth (Clerk) — Phase 11+ ───────────────────────────
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ─── Monitoring — Phase 16+ ─────────────────────────────
SENTRY_DSN=

# ─── App ────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:3000
APP_ENV=development
LOG_LEVEL=INFO
